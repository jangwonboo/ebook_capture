# Copy this file to .env and fill in values for your environment.
# Never commit a real .env with API keys or private paths.

# Required for Google Gemini OCR
GOOGLE_API_KEY=

# Gemini model for OCR. Keep overrideable because model availability changes.
GOOGLE_OCR_MODEL=gemini-2.5-flash

# Trust mode:
# - auto: OS trust store first, certifi fallback
# - system: OS/Windows certificate store only
# - certifi: public CA bundle only (recommended on open networks)
GOOGLE_API_TRUST_MODE=auto

# Optional corporate/root CA bundle (PEM or Windows-exported DER .cer).
# Place the file in the repo root, or set an absolute path.
# GOOGLE_API_CA_BUNDLE=cato-root.cer

# Optional standard SSL variables. Usually leave empty unless required.
# SSL_CERT_FILE=
# SSL_CERT_DIR=

# Optional Google TTS / service account settings if voice features are used.
# GOOGLE_APPLICATION_CREDENTIALS=
